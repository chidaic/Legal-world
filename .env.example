OPENAI_API_KEY=
OPENAI_API_BASE_URL=
OPENAI_MODEL_NAME=
SIMLAW_PROMPT_PROFILE=prod

# Law retrieval is disabled by default in the public repository because the
# vector index is a large external data asset. Enable it only after downloading
# and unpacking the law index from the project Data page.
SIMLAW_ENABLE_LAW_RETRIEVAL=false
LAW_RETRIEVAL_INDEX_DIR=
LAW_EMBEDDING_API_KEY=
LAW_EMBEDDING_API_BASE_URL=
LAW_EMBEDDING_MODEL=
LAW_EMBEDDING_DIMENSIONS=1024

POSTGRES_DB=simlaw
POSTGRES_USER=simlaw
POSTGRES_PASSWORD=change-this-postgres-password
DATABASE_URL=postgresql+psycopg://simlaw:change-this-postgres-password@postgres:5432/simlaw
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE_SECONDS=1800

JWT_SECRET=change-this-jwt-secret
JWT_EXPIRES_MINUTES=60

# Optional Python package index override for backend image builds.
UV_INDEX_URL=

BACKEND_PORT=8000
MAX_CONCURRENT_CASES=1
